import React, { useState } from 'react';
import { 
  Users, 
  BrainCircuit, 
  ActivitySquare, 
  ShoppingCart, 
  CheckCircle2, 
  Target, 
  User, 
  Smartphone, 
  Instagram, 
  BarChart3, 
  Megaphone, 
  Briefcase, 
  Sparkles, 
  Info,
  Send 
} from 'lucide-react';

// Componente de Cartão de Seleção
const SelectCard = ({ title, description, selected, onClick, multi = false }) => (
  <div 
    onClick={onClick}
    className={`
      cursor-pointer p-4 rounded-xl border-2 transition-all duration-200 flex items-start gap-3
      ${selected 
        ? 'border-indigo-600 bg-indigo-50 shadow-md' 
        : 'border-gray-100 bg-white hover:border-indigo-200 hover:bg-gray-50'
      }
    `}
  >
    <div className="mt-0.5">
      <div className={`
        w-5 h-5 flex items-center justify-center border transition-colors
        ${multi ? 'rounded' : 'rounded-full'}
        ${selected ? 'bg-indigo-600 border-indigo-600' : 'border-gray-300 bg-white'}
      `}>
        {selected && <CheckCircle2 className="w-4 h-4 text-white" />}
      </div>
    </div>
    <div className="flex-1">
      <p className={`font-medium ${selected ? 'text-indigo-900' : 'text-gray-700'}`}>
        {title}
      </p>
      {description && (
        <p className={`text-sm mt-1 ${selected ? 'text-indigo-700' : 'text-gray-500'}`}>
          {description}
        </p>
      )}
    </div>
  </div>
);

export default function App() {
  const [profissaoContexto, setProfissaoContexto] = useState('Nutricionista');

  // Variáveis Dinâmicas de Linguagem
  const txtCliente = profissaoContexto === 'Treinador' ? 'aluno' : 'paciente';
  const txtEntrega = profissaoContexto === 'Treinador' ? 'planejamento de treinos' : 'plano alimentar';
  const txtLocal = profissaoContexto === 'Treinador' ? 'atendimento' : 'consultório';

  const [formData, setFormData] = useState({
    // Bloco 1 - Profissional
    nome: '', whatsapp: '', instagram: '',
    equipe: [], atendimento: '', modelo: '',
    ticketProfissional: '', faturamento: '',
    sonho12Meses: '', maiorObstaculo: '',
    
    // Bloco 2 - PPI (O Paciente Ideal)
    ppiDosSonhos: '',
    atendeQuemGostaria: null,
    pacienteAtualDescricao: '',
    maiorDesejoPaciente: '',
    reclamacoesFrequentes: '',
    tentativasPassadas: '',
    motivoAgora: [],
    detalheMotivo: '',
    faseMudanca: '',
    dificuldadesAlimentares: [],
    adesaoPlano: '',
    barreirasExternas: [],
    pesaDecisao: '',
    investimentoPaciente: '',
    ritmoDecisao: '',
    mudancaPercebida: '',
    diferenciais: '',
    antiPPI: ''
  });

  const handleChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => ({ ...prev, [name]: value }));
  };

  const handleSelect = (field, value) => {
    setFormData(prev => ({ ...prev, [field]: value }));
  };

  const handleMultiSelect = (field, value) => {
    setFormData(prev => {
      const current = prev[field] || [];
      if (current.includes(value)) {
        return { ...prev, [field]: current.filter(item => item !== value) };
      } else {
        return { ...prev, [field]: [...current, value] };
      }
    });
  };

  return (
    <div className="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8 font-sans pb-24">
      <div className="max-w-4xl mx-auto">
        
        {/* SIMULADOR DE CONTEXTO */}
        <div className="bg-indigo-900 text-white p-4 rounded-xl mb-8 flex items-center justify-between shadow-lg sticky top-4 z-50">
          <div>
            <p className="text-sm text-indigo-200 font-bold uppercase tracking-wider italic">Modo de Visualização</p>
          </div>
          <div className="flex gap-2 bg-indigo-950 p-1 rounded-lg">
            <button 
