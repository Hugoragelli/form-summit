              {/* Atual vs Ideal */}
              <div>
                <label className="block text-base font-bold text-gray-900 mb-4">2. Você está atendendo hoje quem você realmente gostaria?</label>
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <SelectCard title="Sim, meu público atual é o ideal" selected={formData.atendeQuemGostaria === true} onClick={() => handleSelect('atendeQuemGostaria', true)} />
