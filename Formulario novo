            >
              Treinador
            </button>
          </div>
        </div>

        {/* Intro */}
        <div className="mb-12 text-center">
          <h1 className="text-4xl font-extrabold text-gray-900 mb-4 tracking-tight">
            Mapeamento Estratégico NSF
          </h1>
          <div className="max-w-2xl mx-auto bg-white p-6 rounded-2xl border border-indigo-100 shadow-sm flex items-start gap-4 text-left">
            <div className="bg-indigo-100 p-2 rounded-lg">
              <Info className="w-6 h-6 text-indigo-600" />
            </div>
            <p className="text-gray-600 text-sm leading-relaxed">
              <strong>Importante:</strong> Quanto mais preciso for o preenchimento, melhor nossa IA conseguirá desenhar seu <strong>Posicionamento e Perfil de Paciente Ideal (PPI)</strong>. Siga as orientações em "Detalhes" para cada campo.
            </p>
          </div>
        </div>

        <div className="space-y-10">
          
          {/* BLOCO 1: O PROFISSIONAL */}
          <div className="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
            <div className="bg-indigo-600 p-6 text-white flex items-center gap-3">
              <Briefcase className="w-6 h-6" />
              <h2 className="text-xl font-bold italic tracking-wide uppercase">O Profissional</h2>
            </div>
            
            <div className="p-8 space-y-10">
              {/* Identificação */}
              <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                  <label className="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Seu Nome</label>
                  <input type="text" name="nome" value={formData.nome} onChange={handleChange} className="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl" placeholder="Nome Completo" />
                </div>
                <div>
