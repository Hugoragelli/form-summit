                  </div>
                </div>

                <div>
                  <label className="block text-base font-bold text-gray-900 mb-3">9. Como ele lida com o {txtEntrega}?</label>
                  <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <SelectCard title="Focado / Disciplinado" selected={formData.adesaoPlano === 'Focado'} onClick={() => handleSelect('adesaoPlano', 'Focado')} />
