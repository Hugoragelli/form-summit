              </div>

              {/* Condicional: Só aparece se a resposta acima for "Não" */}
              {formData.atendeQuemGostaria === false && (
                <div className="animate-in fade-in slide-in-from-top-4 duration-300">
                  <label className="block text-base font-bold text-gray-900 mb-2">3. Quem é o {txtCliente} que MAIS aparece hoje no seu {txtLocal}?</label>
                  <p className="text-sm text-gray-500 mb-3 italic"><strong>Detalhes:</strong> Descreva um caso real recente. Inclua idade, profissão e o nível de comprometimento/dificuldade desse perfil.</p>
                  <textarea 
                    name="pacienteAtualDescricao" 
                    value={formData.pacienteAtualDescricao} 
                    onChange={handleChange} 
                    rows="3" 
                    className="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-600 transition-all resize-none"
                    placeholder='Ex: "Aparecem muitas pessoas buscando apenas uma consulta pontual, focadas no menor preço e que desistem do plano após 30 dias..."'
                  />
