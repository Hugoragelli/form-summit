                </div>
              </div>

              {/* Equipe e Modelo */}
              <div className="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div>
                  <label className="block text-base font-bold text-gray-900 mb-4">Estrutura de Equipe</label>
                  <div className="grid grid-cols-1 gap-3">
