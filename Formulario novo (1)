// Componente de Cartão de Seleção Otimizado
const SelectCard = ({ title, description, selected, onClick, multi = false }) => (
  <div 
    onClick={onClick}
    className={`
      cursor-pointer p-4 rounded-2xl border-2 transition-all duration-200 flex items-start gap-4 h-full
      ${selected 
        ? 'border-indigo-600 bg-indigo-50 shadow-md transform scale-[1.01]' 
        : 'border-slate-100 bg-white hover:border-indigo-200 hover:bg-slate-50'
      }
    `}
  >
    <div className="mt-1">
      <div className={`
        w-6 h-6 flex items-center justify-center border-2 transition-colors
        ${multi ? 'rounded-lg' : 'rounded-full'}
        ${selected ? 'bg-indigo-600 border-indigo-600' : 'border-slate-300 bg-white'}
      `}>
        {selected && <CheckCircle2 className="w-4 h-4 text-white" />}
      </div>
    </div>
    <div className="flex-1">
      <p className={`text-sm font-bold ${selected ? 'text-indigo-950' : 'text-slate-700'}`}>
        {title}
      </p>
      {description && (
        <p className={`text-xs mt-1 leading-relaxed ${selected ? 'text-indigo-800' : 'text-slate-500'}`}>
          {description}
        </p>
      )}
    </div>
  </div>
);

