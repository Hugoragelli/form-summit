                    className="w-full p-6 bg-slate-50 border-2 border-slate-50 rounded-[1.8rem] focus:border-indigo-500 focus:bg-white transition-all outline-none font-bold text-slate-800 shadow-inner resize-none" 
                    placeholder='Ex: "Monitoramento semanal via Wellts + Suporte direto para ajustes de viagens e eventos sociais em tempo real..."' />
                </div>

                <div className="bg-red-50 p-8 md:p-10 rounded-[2.5rem] border-2 border-red-100 shadow-sm">
                  <h3 className="text-xl font-black text-red-950 mb-4 leading-tight flex items-center gap-3">
                    <XOctagon className="text-red-600" />
                    Quem você DETESTA atender? (O seu Anti-PPI)
                  </h3>
                  <p className="text-sm text-red-800/70 mb-6 font-bold leading-relaxed">
                    Descreva os perfis de pacientes ou alunos que sugam sua energia e não têm fit nenhum com o seu método.
                  </p>
                  <textarea name="antiPPI" value={formData.antiPPI} onChange={handleChange} rows="4" 
                    className="w-full p-6 bg-white border-2 border-red-100 rounded-[1.8rem] focus:border-red-500 transition-all outline-none font-bold text-red-900 shadow-sm resize-none" 
                    placeholder='Ex: "Pessoas que buscam fórmulas mágicas (canetas emagrecedoras) e não querem mudar um único hábito de rotina..."' />
                </div>
              </div>

            </div>
          </div>

          {/* Botão de Envio */}
          <div className="flex flex-col items-center gap-8 pt-10">
            <button className="group relative flex items-center gap-4 px-20 py-8 bg-indigo-600 hover:bg-indigo-700 text-white text-2xl font-black rounded-[2.5rem] shadow-[0_30px_60px_rgba(79,70,229,0.3)] transition-all transform hover:-translate-y-2 active:scale-95">
              FINALIZAR DIAGNÓSTICO
              <Send className="w-7 h-7 group-hover:translate-x-2 transition-transform" />
            </button>
            <p className="text-slate-400 text-[10px] font-black uppercase tracking-[0.4em] italic">Nutrição Sem Fronteiras © 2026</p>
